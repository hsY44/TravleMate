<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    noticeMapper.xml
    - 공지사항 관련 SQL
    - namespace : com.doit.app.mapper.NoticeMapper
-->
<mapper namespace="com.doit.app.mapper.NoticeMapper">

    <!--
        countNotices
        - 공지사항 전체 건수 (페이징 계산용)
    -->
    <select id="countNotices" resultType="int">
        SELECT COUNT(1) FROM NOTICE
    </select>


    <!--
        selectNotices
        - 공지사항 목록 조회 — 페이징 (최신 등록순)
    -->
    <select id="selectNotices" resultType="com.doit.app.domain.NoticeVo">
        SELECT *
          FROM (
            SELECT A.*, ROWNUM AS rn
              FROM (
                SELECT NOTICE_NO                               AS noticeNo
                     , ADMIN_NO                                AS adminNo
                     , NOTICE_TITLE                            AS noticeTitle
                     , VIEW_CNT                                AS viewCnt
                     , TO_CHAR(CREATE_DT, 'YYYY-MM-DD')       AS createDt
                  FROM NOTICE
                 ORDER BY CREATE_DT DESC
              ) A
             WHERE ROWNUM &lt;= #{endRow}
          )
         WHERE rn &gt;= #{startRow}
    </select>


    <!--
        selectNoticeByNo
        - 공지사항 단건 조회 (NOTICE_CONTENT 포함)
    -->
    <select id="selectNoticeByNo" resultType="com.doit.app.domain.NoticeVo">
        SELECT NOTICE_NO                               AS noticeNo
             , ADMIN_NO                                AS adminNo
             , NOTICE_TITLE                            AS noticeTitle
             , NOTICE_CONTENT                          AS noticeContent
             , VIEW_CNT                                AS viewCnt
             , TO_CHAR(CREATE_DT, 'YYYY-MM-DD')       AS createDt
          FROM NOTICE
         WHERE NOTICE_NO = #{noticeNo}
    </select>


    <!--
        updateViewCnt
        - 조회수 1 증가 (상세 조회 시 호출)
    -->
    <update id="updateViewCnt">
        UPDATE NOTICE
           SET VIEW_CNT = VIEW_CNT + 1
         WHERE NOTICE_NO = #{noticeNo}
    </update>

</mapper>
