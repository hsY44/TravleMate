<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    memberMapper.xml
    - 회원 관련 SQL
    - namespace : com.doit.app.mapper.MemberMapper

    ※ DB 컬럼명 ↔ Java 필드명 매핑 주의 항목
       MEMBER_ACTIVE.ID       → loginId
       MEMBER_ACTIVE.PHONE_NO → phoneNo

    ※ 시퀀스 이름 : MEMBER_MASTER_SEQ (DB 시퀀스 생성.sql 기준)
-->
<mapper namespace="com.doit.app.mapper.MemberMapper">

    <!--
        resultMap : MemberVo
        - 컬럼명과 필드명이 다른 항목만 명시 (나머지는 MyBatis 자동 매핑)
        - ID       → loginId
        - PHONE_NO → phoneNo
        - MEMBER_NO → memberNo  (underscore → camelCase 비활성화이므로 명시)
    -->
    <resultMap id="memberVoMap" type="com.doit.app.domain.MemberVo">
        <id     column="MEMBER_NO" property="memberNo"/>
        <result column="NAME"      property="name"/>
        <result column="NICKNAME"  property="nickname"/>
        <result column="ID"        property="loginId"/>
        <result column="EMAIL"     property="email"/>
        <result column="PHONE_NO"  property="phoneNo"/>
        <!-- pw 는 로그인 성공 후 세션에 저장하지 않으므로 매핑 제외 -->
    </resultMap>


    <!--
        insertMemberMaster
        - MEMBER_MASTER 테이블에 INSERT
        - selectKey : MEMBER_MASTER_SEQ.NEXTVAL → vo.memberNo 에 저장
          (insertMemberActive 에서 같은 memberNo 를 FK 로 사용)
    -->
    <insert id="insertMemberMaster" parameterType="com.doit.app.domain.MemberVo">
        <selectKey keyProperty="memberNo" resultType="Long" order="BEFORE">
            SELECT MEMBER_MASTER_SEQ.NEXTVAL FROM DUAL
        </selectKey>
        INSERT INTO MEMBER_MASTER
            (MEMBER_NO, CREATE_DT)
        VALUES
            (#{memberNo}, SYSDATE)
    </insert>


    <!--
        insertMemberActive
        - MEMBER_ACTIVE 테이블에 INSERT
        - memberNo 는 insertMemberMaster 에서 채워진 값을 그대로 사용
        - PW 는 CRYPTPACK.ENCRYPT(평문, 키) 로 암호화하여 저장
    -->
    <insert id="insertMemberActive" parameterType="com.doit.app.domain.MemberVo">
        INSERT INTO MEMBER_ACTIVE
            (MEMBER_NO, NAME, NICKNAME, ID, PW, EMAIL, PHONE_NO)
        VALUES
            (#{memberNo}, #{name}, #{nickname}, #{loginId},
             CRYPTPACK.ENCRYPT(#{pw}, #{encKey}),
             #{email}, #{phoneNo})
    </insert>


    <!--
        selectMemberLogin
        - 아이디·비밀번호로 회원 조회
        - 입력 PW 를 ENCRYPT 한 결과와 DB 저장값 비교
    -->
    <select id="selectMemberLogin" parameterType="com.doit.app.domain.MemberVo" resultMap="memberVoMap">
        SELECT MA.MEMBER_NO
             , MA.NAME
             , MA.NICKNAME
             , MA.ID
             , MA.EMAIL
             , MA.PHONE_NO
          FROM MEMBER_ACTIVE MA
          JOIN MEMBER_MASTER MM ON MM.MEMBER_NO = MA.MEMBER_NO
         WHERE MA.ID = #{loginId}
           AND MA.PW = CRYPTPACK.ENCRYPT(#{pw}, #{encKey})
    </select>


    <!--
        checkSuspension
        - 현재 유효한 제재(정지) 이력이 있는지 확인
        - SANCTION_UNTIL > SYSDATE 인 행이 1건 이상이면 정지 상태
        - 로그인 처리 시 비밀번호 일치 확인 후 이 쿼리로 정지 여부 추가 확인
    -->
    <select id="checkSuspension" resultType="int">
        SELECT COUNT(1)
          FROM MEMBER_SANCTION
         WHERE MEMBER_NO      = #{memberNo}
           AND SANCTION_UNTIL > SYSDATE
    </select>


    <!--
        countById
        - 아이디 중복 확인
        - 0: 사용 가능 / 1 이상: 이미 존재
    -->
    <select id="countById" resultType="int">
        SELECT COUNT(1)
          FROM MEMBER_ACTIVE
         WHERE ID = #{loginId}
    </select>


    <!--
        countByNickname
        - 닉네임 중복 확인
    -->
    <select id="countByNickname" resultType="int">
        SELECT COUNT(1)
          FROM MEMBER_ACTIVE
         WHERE NICKNAME = #{nickname}
    </select>


    <!--
        countByNicknameExcludeSelf
        - 닉네임 중복 확인 — 정보수정 시 사용
        - 자기 자신(memberNo)은 제외하여 현재 닉네임과 동일해도 통과
    -->
    <select id="countByNicknameExcludeSelf" resultType="int">
        SELECT COUNT(1)
          FROM MEMBER_ACTIVE
         WHERE NICKNAME   = #{nickname}
           AND MEMBER_NO != #{memberNo}
    </select>


    <!--
        updateMember
        - 회원 정보 수정 (이름, 닉네임, 이메일, 휴대폰번호)
        - pw 가 입력된 경우에만 비밀번호도 함께 변경
    -->
    <update id="updateMember" parameterType="com.doit.app.domain.MemberVo">
        UPDATE MEMBER_ACTIVE
           SET NAME     = #{name}
             , NICKNAME = #{nickname}
             , EMAIL    = #{email}
             , PHONE_NO = #{phoneNo}
             <if test="pw != null and pw != ''">
             , PW       = CRYPTPACK.ENCRYPT(#{pw}, #{encKey})
             </if>
         WHERE MEMBER_NO = #{memberNo}
    </update>


    <!--
        selectBookmarksByMemberNo
        - 특정 회원의 즐겨찾기 목록 조회
        - MEMBER_BOOKMARK → CONTENT → CONTENTCATEGORY JOIN
        - 최신 등록순 정렬
    -->
    <select id="selectBookmarksByMemberNo" resultType="com.doit.app.domain.BookmarkVo">
        SELECT MB.BOOKMARK_NO                              AS bookmarkNo
             , MB.MEMBER_NO                               AS memberNo
             , MB.CONTENTID                               AS contentId
             , C.TITLE                                    AS title
             , C.ADDR1                                    AS addr1
             , CC.CONTENTDIV                              AS contentDiv
             , TO_CHAR(MB.CREATE_DT, 'YYYY-MM-DD')       AS createDt
          FROM MEMBER_BOOKMARK MB
          JOIN CONTENT C          ON C.CONTENTID       = MB.CONTENTID
          LEFT JOIN CONTENTCATEGORY CC ON CC.CONTENTTYPEID = C.CONTENTTYPEID
         WHERE MB.MEMBER_NO = #{memberNo}
         ORDER BY MB.CREATE_DT DESC
    </select>


    <!--
        insertMemberLeave
        - MEMBER_ACTIVE 의 데이터를 MEMBER_LEAVE 로 복사 (SELECT-INSERT)
        - 세션에는 pw 가 없으므로 DB에서 직접 SELECT 하여 INSERT
        - LEAVE_DT 는 DEFAULT SYSDATE
    -->
    <insert id="insertMemberLeave">
        INSERT INTO MEMBER_LEAVE
            (MEMBER_NO, NAME, NICKNAME, ID, PW, EMAIL, PHONE_NO, LEAVE_DT)
        SELECT MEMBER_NO, NAME, NICKNAME, ID, PW, EMAIL, PHONE_NO, SYSDATE
          FROM MEMBER_ACTIVE
         WHERE MEMBER_NO = #{memberNo}
    </insert>


    <!--
        deleteMemberActive
        - MEMBER_ACTIVE 에서 회원 행 삭제
    -->
    <delete id="deleteMemberActive">
        DELETE FROM MEMBER_ACTIVE
         WHERE MEMBER_NO = #{memberNo}
    </delete>


    <!--
        selectReviewsByMemberNo
        - 특정 회원의 리뷰 목록 조회
        - CONTENT_REVIEW → CONTENT JOIN
        - 최신 작성순 정렬
    -->
    <select id="selectReviewsByMemberNo" resultType="com.doit.app.domain.ReviewVo">
        SELECT CR.CONTENT_REVIEW_NO                       AS contentReviewNo
             , CR.MEMBER_NO                               AS memberNo
             , CR.CONTENTID                               AS contentId
             , C.TITLE                                    AS title
             , CR.REVIEW_COMMENT                          AS reviewComment
             , CR.RATING                                  AS rating
             , TO_CHAR(CR.CREATE_DT, 'YYYY-MM-DD')       AS createDt
          FROM CONTENT_REVIEW CR
          JOIN CONTENT C ON C.CONTENTID = CR.CONTENTID
         WHERE CR.MEMBER_NO = #{memberNo}
         ORDER BY CR.CREATE_DT DESC
    </select>

</mapper>
